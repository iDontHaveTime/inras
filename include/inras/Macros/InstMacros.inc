#define X86ARITH_AX_EXCEPTION_ADDR(NAME, ADDR)             \
    if(ADDR_IS_REG(ADDR) &&                                \
       GET_ADDR_REG_ENC(ADDR) == GET_REG_ENC(regs::rax) && \
       !GET_ADDR_REXRM(ADDR))                              \
        return GET_ENC_NAME(NAME)(INST, GET_ADDR_REG_SIZE(ADDR), IMM);

